# Backend LLM provider.
# Use azure_openai for Azure OpenAI, or mock for local UI-only development.
LLM_PROVIDER=azure_openai

# Comma-separated frontend origins allowed to call the backend.
# Add your Vercel frontend URL in production, for example:
# CORS_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Azure OpenAI v1 endpoint.
# Important: include /openai/v1/ at the end.
AZURE_OPENAI_BASE_URL=https://<your-resource-name>.openai.azure.com/openai/v1/

# Azure OpenAI API key from Azure AI Foundry / Azure OpenAI resource.
# No az login or Azure credential flow is used.
AZURE_OPENAI_API_KEY=<your-api-key>

# Use your Azure deployment name here. It may be something like gpt-4.1,
# req-plan-gpt41, or whatever name you gave the deployment in Foundry.
AZURE_OPENAI_DEPLOYMENT=gpt-4.1

# Optional generation settings.
AZURE_OPENAI_TEMPERATURE=0.2
AZURE_OPENAI_MAX_OUTPUT_TOKENS=6000

# Optional Draw.io MCP integration. Leave empty until the remote MCP server is ready.
DRAWIO_MCP_URL=
DRAWIO_MCP_SERVER_LABEL=drawio
DRAWIO_MCP_REQUIRE_APPROVAL=never
DRAWIO_MCP_AUTHORIZATION=
DRAWIO_MCP_ALLOWED_TOOLS=
